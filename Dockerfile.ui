# syntax=docker/dockerfile:1
# UI estática (Vite) servida por nginx. En build, define la URL pública del API, p. ej.:
#   docker build -f Dockerfile.ui --build-arg VITE_API_BASE_URL=https://api.tu-dominio.com -t atlasvpn-ui .
FROM node:22-bookworm-slim AS build
WORKDIR /app/ui
COPY ui/package.json ui/package-lock.json ./
RUN npm ci
COPY ui/ ./
ARG VITE_API_BASE_URL=
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL
RUN npm run build

FROM nginx:1.27-alpine
COPY deploy/nginx-ui.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/atlasvpn/static/web /usr/share/nginx/html
EXPOSE 80
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
  CMD wget -qO- http://127.0.0.1/ >/dev/null || exit 1
